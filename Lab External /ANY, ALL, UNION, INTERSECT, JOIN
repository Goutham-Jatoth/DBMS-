Querying (using ANY, ALL, UNION, INTERSECT, JOIN, Constraints etc.) 


Program 1: JOIN + Constraints
Step 1: Create Tables
CREATE TABLE Student (
    RollNo INT PRIMARY KEY,
    Name VARCHAR(30),
    Dept VARCHAR(10)
);

CREATE TABLE Marks (
    RollNo INT,
    Subject VARCHAR(20),
    Marks INT CHECK (Marks BETWEEN 0 AND 100),
    FOREIGN KEY (RollNo) REFERENCES Student(RollNo)
);
Step 2: Insert Data
INSERT INTO Student VALUES (101, 'Ravi', 'CSE');
INSERT INTO Student VALUES (102, 'Anu', 'ECE');
INSERT INTO Student VALUES (103, 'Kiran', 'EEE');

INSERT INTO Marks VALUES (101, 'DBMS', 85);
INSERT INTO Marks VALUES (101, 'OS', 78);
INSERT INTO Marks VALUES (102, 'DBMS', 92);
INSERT INTO Marks VALUES (103, 'OS', 60);
Step 3: INNER JOIN
SELECT S.Name, M.Subject, M.Marks
FROM Student S
INNER JOIN Marks M
ON S.RollNo = M.RollNo;












Program 2: ANY Operator
Query

Find students who scored more than 80 in any subject

SELECT Name
FROM Student
WHERE RollNo = ANY (
    SELECT RollNo FROM Marks WHERE Marks > 80
);




Program 3: ALL Operator
Query

Find students whose marks are greater than all students scoring below 70

SELECT Name
FROM Student
WHERE RollNo = ALL (
    SELECT RollNo FROM Marks WHERE Marks < 70
);





Program 4: UNION Operation
Step 1: Create Another Table
CREATE TABLE Sports (
    RollNo INT
);
Step 2: Insert Data
INSERT INTO Sports VALUES (101);
INSERT INTO Sports VALUES (104);
Step 3: UNION Query
SELECT RollNo FROM Student
UNION
SELECT RollNo FROM Sports;






Program 5: INTERSECT Operation
Query

Find common RollNos in both tables

SELECT RollNo FROM Student
INTERSECT
SELECT RollNo FROM Sports;




Program 6: LEFT JOIN
Query

Display all students with marks (including those without marks)

SELECT S.Name, M.Marks
FROM Student S
LEFT JOIN Marks M
ON S.RollNo = M.RollNo;






Program 7: RIGHT JOIN
SELECT S.Name, M.Marks
FROM Student S
RIGHT JOIN Marks M
ON S.RollNo = M.RollNo;





Program 8: Constraint Checking
Invalid Insert
INSERT INTO Marks VALUES (105, 'DBMS', 120); -- Fails (CHECK constraint)








Program 9: Combined Query (JOIN + ANY)
SELECT Name
FROM Student
WHERE RollNo = ANY (
    SELECT RollNo FROM Marks WHERE Marks > 90
);









Program 10: Combined Query (JOIN + GROUP)
SELECT S.Name, AVG(M.Marks)
FROM Student S
JOIN Marks M ON S.RollNo = M.RollNo
GROUP BY S.Name;
