Triggers (Creation of insert trigger, delete trigger, update trigger) 


Program 1: Basic Logging Trigger (All 3 Types)
Step 1: Create Tables
CREATE TABLE Student (
    RollNo INT PRIMARY KEY,
    Name VARCHAR(30),
    Dept VARCHAR(10)
);

CREATE TABLE Student_Log (
    RollNo INT,
    Action VARCHAR(10),
    Action_Time DATE
);
Step 2: Create Triggers
INSERT Trigger
CREATE OR REPLACE TRIGGER trg_insert
AFTER INSERT ON Student
FOR EACH ROW
BEGIN
    INSERT INTO Student_Log VALUES (:NEW.RollNo, 'INSERT', SYSDATE);
END;
UPDATE Trigger
CREATE OR REPLACE TRIGGER trg_update
AFTER UPDATE ON Student
FOR EACH ROW
BEGIN
    INSERT INTO Student_Log VALUES (:OLD.RollNo, 'UPDATE', SYSDATE);
END;
DELETE Trigger
CREATE OR REPLACE TRIGGER trg_delete
AFTER DELETE ON Student
FOR EACH ROW
BEGIN
    INSERT INTO Student_Log VALUES (:OLD.RollNo, 'DELETE', SYSDATE);
END;
Step 3: Test Triggers
